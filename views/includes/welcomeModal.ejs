<div
  class="modal fade"
  id="welcomeModal"
  tabindex="-1"
  data-bs-backdrop="static"
  data-bs-keyboard="false"
>
  <div class="modal-dialog modal-dialog-centered welcome-dialog">
    <div class="modal-content welcome-modal">
      <div class="modal-header">
        <h3 class="fw-bold text-danger mb-0">🏡 StayNix</h3>

        <button type="button" class="btn-close" id="closeWelcome"></button>
      </div>

      <div class="modal-body">
        <h4 class="fw-bold mb-3">Welcome to StayNix</h4>

        <p>
          StayNix is a full-stack property rental platform where users can
          discover, publish, and review accommodations securely.
        </p>

        <hr />

        <h5 class="fw-bold">Project Features</h5>

        <ol>
          <li>Browse all listings without logging in.</li>

          <li>Login or Sign Up to create your own listings.</li>

          <li>Only logged-in users can add reviews.</li>

          <li>Only the listing owner can edit or delete their listings.</li>

          <li>Only the review owner can delete their reviews.</li>
        </ol>

       <hr>

        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="dontShowAgain" />

          <label class="form-check-label" for="dontShowAgain">
            Don't show this again
          </label>
        </div>
      </div>

        <div class="modal-footer">
          <button class="btn btn-danger px-4" id="exploreBtn">
            Start Exploring
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
