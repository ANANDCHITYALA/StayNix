<% layout("layouts/boilerplate.ejs") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
      <div class="auth-card">
        <div class="text-center mb-4">
          <i class="fa-solid fa-house auth-icon"></i>

          <h2 class="fw-bold mt-3">Welcome Back 👋</h2>

          <p class="text-muted">Login to continue exploring StayNix.</p>
        </div>

        <form method="POST" action="/login" class="needs-validation" novalidate>
          <div class="mb-3">
            <label class="form-label"> Username </label>

            <input
              type="text"
              name="username"
              class="form-control form-control-lg"
              required
            />

            <div class="invalid-feedback">Please enter your username.</div>
          </div>

          <div class="mb-4">
            <label class="form-label"> Password </label>

            <input
              type="password"
              name="password"
              class="form-control form-control-lg"
              required
            />

            <div class="invalid-feedback">Please enter your password.</div>
          </div>

          <button class="btn btn-danger w-100 py-2">Login</button>
        </form>

        <hr />

        <p class="text-center mb-0">
          Don't have an account?

          <a
            href="/signup"
            class="text-danger fw-semibold text-decoration-none"
          >
            Sign Up
          </a>
        </p>
      </div>
    </div>
  </div>
</div>
