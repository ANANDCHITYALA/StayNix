<% layout("layouts/boilerplate.ejs") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
      <div class="auth-card">
        <div class="text-center mb-4">
          <i class="fa-solid fa-house auth-icon"></i>

          <h2 class="fw-bold mt-3">Create Account</h2>

          <p class="text-muted">Join StayNix and start hosting or booking.</p>
        </div>

        <form
          action="/signup"
          method="POST"
          class="needs-validation"
          novalidate
        >
          <div class="mb-3">
            <label class="form-label"> Username </label>

            <input
              type="text"
              name="username"
              class="form-control form-control-lg"
              required
            />
          </div>

          <div class="mb-3">
            <label class="form-label"> Email </label>

            <input
              type="email"
              name="Email"
              class="form-control form-control-lg"
              required
            />
          </div>

          <div class="mb-4">
            <label class="form-label"> Password </label>

            <input
              type="password"
              name="password"
              class="form-control form-control-lg"
              required
            />
          </div>

          <button class="btn btn-danger w-100 py-2">Create Account</button>
        </form>

        <hr />

        <p class="text-center mb-0">
          Already have an account?

          <a href="/login" class="text-danger fw-semibold text-decoration-none">
            Login
          </a>
        </p>
      </div>
    </div>
  </div>
</div>
