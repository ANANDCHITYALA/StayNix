<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-md-8 offset-2">
    <h3>Create new listing</h3>
    <form
      method="post"
      action="/listings/new"
      class="needs-validation"
      enctype="multipart/form-data"
      novalidate
    >
      <div>
        <label for="title" class="form-label">Title:</label>
        <input
          type="text"
          name="listings[title]"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a Title.</div>
      </div>

      <div>
        <label for="description" class="form-label"> Description:</label>
        <textarea
          name="listings[description]"
          id=""
          class="form-control"
          required
        ></textarea>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please add description.</div>
      </div>

      <div class="mb-3">
        <label class="form-label"> Upload Image </label>

        <input type="file" name="image" class="form-control" required />
      </div>

      <div>
        <label for="price" class="form-label">price</label>
        <input
          type="number"
          min="1"
          name="listings[price]"
          id=""
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">price is mandatory to enter</div>
      </div>

      <div>
        <label for="location" class="form-label">location</label>
        <input
          type="text"
          name="listings[location]"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please choose a location.</div>
      </div>

      <div>
        <label for="country" class="form-label">country</label>
        <input
          type="text"
          name="listings[country]"
          id=""
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please choose a country.</div>
      </div>
      <br />
      <div>
        <button class="btn btn-primary" type="submit">Submit form</button>
      </div>
    </form>
  </div>
</div>
