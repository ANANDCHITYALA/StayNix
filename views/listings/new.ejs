<% layout("layouts/boilerplate.ejs") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="form-card">
        <div class="text-center mb-5">
          <i class="fa-solid fa-house-circle-check form-icon"></i>

          <h2 class="fw-bold mt-3">Create New Listing</h2>

          <p class="text-muted">
            Share your property with travelers around the world.
          </p>
        </div>

        <form
          action="/listings/new"
          method="POST"
          enctype="multipart/form-data"
          class="needs-validation"
          novalidate
        >
          <div class="mb-4">
            <label class="form-label"> Property Title </label>

            <input
              type="text"
              class="form-control"
              name="listings[title]"
              required
            />
          </div>

          <div class="mb-4">
            <label class="form-label"> Description </label>

            <textarea
              rows="5"
              class="form-control"
              name="listings[description]"
              required
            ></textarea>
          </div>

          <div class="row">
            <div class="col-md-6 mb-4">
              <label class="form-label"> Price (₹) </label>

              <input
                type="number"
                min="1"
                class="form-control"
                name="listings[price]"
                required
              />
            </div>

            <div class="col-md-6 mb-4">
              <label class="form-label"> Upload Image </label>

              <input type="file" class="form-control" name="image" />
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-4">
              <label class="form-label"> Location </label>

              <input
                type="text"
                class="form-control"
                name="listings[location]"
                required
              />
            </div>

            <div class="col-md-6 mb-4">
              <label class="form-label"> Country </label>

              <input
                type="text"
                class="form-control"
                name="listings[country]"
                required
              />
            </div>
          </div>

          <button class="btn btn-danger btn-lg w-100">Publish Listing</button>
        </form>
      </div>
    </div>
  </div>
</div>
