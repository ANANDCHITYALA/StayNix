<% layout("layouts/boilerplate.ejs") %>

<div class="container py-5">

  <div class="row g-5">

    <!-- Left Side -->

    <div class="col-lg-8">

      <div class="listing-image-wrapper">

  <img
    src="<%= hotel.image.url %>"
    class="listing-hero-img"
    alt="<%= hotel.title %>"
  >

</div>

      <div class="mt-4">

        <h2 class="fw-bold">

          <%= hotel.title %>

        </h2>

        <div class="d-flex align-items-center gap-3 mt-2">

          <span
            class="starability-result"
            data-rating="<%= Math.round(averageRating) %>"
          >
            Rated:
            <%= averageRating %>
          </span>

          <span class="text-muted">

            (<%= hotel.reviews.length %> Reviews)

          </span>

        </div>

        <p class="text-muted mt-3 mb-4">

          <i class="fa-solid fa-location-dot text-danger"></i>

          <%= hotel.location %>,

          <%= hotel.country %>

        </p>

        <hr>

        <h5 class="fw-semibold">

          About this stay

        </h5>

        <p class="listing-description">

          <%= hotel.description %>

        </p>

      </div>

    </div>

    <!-- Right Side -->

    <div class="col-lg-4">

      <div class="booking-card">

        <h3 class="fw-bold">

          ₹ <%= hotel.price %>

          <span class="fs-6 fw-normal">

            / night

          </span>

        </h3>

        <hr>

        <p>

          <i class="fa-solid fa-user me-2"></i>

          Hosted by

          <strong>

            <% if(hotel.author){ %>

              @<%= hotel.author.username %>

            <% } %>

          </strong>

        </p>

        <div class="d-grid mt-4">

          <button class="btn btn-danger btn-lg">

            Reserve

          </button>

        </div>

        <% if(
          currUser &&
          hotel.author &&
          hotel.author._id.toString()===currUser._id.toString()
        ){ %>

        <div class="d-grid gap-2 mt-4">

          <a
            href="/view/<%= hotel._id %>/edit"
            class="btn btn-outline-dark"
          >

            <i class="fa-solid fa-pen me-2"></i>

            Edit Listing

          </a>

          <form
            method="POST"
            action="/view/<%= hotel._id %>/delete?_method=DELETE"
          >

            <button
              class="btn btn-outline-danger w-100"
            >

              <i class="fa-solid fa-trash me-2"></i>

              Delete Listing

            </button>

          </form>

        </div>

        <% } %>

      </div>

    </div>

  </div>

</div>

<hr class="mb-5">

  <!-- ================= Review Form ================= -->

<div class="container mb-5">

  <% if(currUser){ %>

  <div class="row justify-content-center">

    <div class="col-lg-8">

      <div class="review-form-card">

        <h3 class="fw-bold mb-4">

          Leave a Review

        </h3>

        <form
          action="/listings/<%= hotel._id %>/reviews"
          method="POST"
        >

          <fieldset class="starability-slot mb-4">

            <input
              type="radio"
              id="no-rate"
              class="input-no-rate"
              name="review[rating]"
              value="1"
              checked
              aria-label="No rating."
            />

            <% for(let i=1;i<=5;i++){ %>

            <input
              type="radio"
              id="rate<%=i%>"
              name="review[rating]"
              value="<%=i%>"
            >

            <label
              for="rate<%=i%>"
            >
              <%=i%>
            </label>

            <% } %>

          </fieldset>

          <textarea
            class="form-control mb-3"
            rows="5"
            placeholder="Share your experience..."
            name="review[comment]"
            required
          ></textarea>

          <button class="btn btn-danger px-5">

            Submit Review

          </button>

        </form>

      </div>

    </div>

  </div>

  <% } else { %>

  <div class="alert alert-light border shadow-sm text-center">

      <h5>

        Want to leave a review?

      </h5>

      <a
        href="/login"
        class="btn btn-danger mt-2"
      >

        Login

      </a>

  </div>

  <% } %>

</div>

<!-- ================= Reviews ================= -->

<div class="container">

<h3 class="fw-bold mb-4">

Guest Reviews

</h3>

<% if(hotel.reviews.length===0){ %>

<div class="empty-review">

<i class="fa-regular fa-face-smile"></i>

<p>

Be the first one to review this stay.

</p>

</div>

<% } %>

<div class="row">

<% hotel.reviews.forEach((review)=>{ %>

<div class="col-lg-6 mb-4">

<div class="review-card">

<div class="d-flex justify-content-between">

<div>

<h5>

<i class="fa-solid fa-circle-user me-2"></i>

@<%= review.author.username %>

</h5>

<small class="text-muted">

<%= review.createdAt.toDateString() %>

</small>

</div>

<span
class="starability-result"
data-rating="<%=review.rating%>"
>

Rated:

<%=review.rating%>

</span>

</div>

<hr>

<p>

<%= review.comment %>

</p>

<% if(
currUser &&
review.author &&
review.author._id.toString()===currUser._id.toString()
){ %>

<form
method="POST"
action="/listings/<%=hotel._id%>/reviews/<%=review._id%>?_method=DELETE"
>

<button
class="btn btn-outline-danger btn-sm"
>

Delete Review

</button>

</form>

<% } %>

</div>

</div>

<% }) %>

</div>

</div>