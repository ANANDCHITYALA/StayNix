<% layout("/layouts/boilerplate.ejs") %>

<div class="row">
  <div class="col-md-5 offset-2">
    <form
      method="post"
      action="/listings/<%= hotel._id %>?_method=PUT"
      class="needs-validation"
      novalidate
    >
      <div>
        <label for="title" class="form-label">Title:</label>
        <input
          type="text"
          name="listings[title]"
          class="form-control"
          value="<%= hotel.title %>"
          required
        />
        <div class="invalid-feedback">Please enter a Title.</div>
      </div>

      <div>
        <label for="description" class="form-label"> Description:</label>
        <textarea name="listings[description]" class="form-control" required>
<%= hotel.description %></textarea
        >
        <div class="invalid-feedback">Please add description.</div>
      </div>

      <div class="row">
        <div class="col-md-8">
          <label for="image[filename]" class="form-label">image name</label>
          <input
            type="text"
            name="listings[image][filename]"
            id="image[filename]"
            class="form-control"
            value="<%= hotel.image.name %>"
          />
          <div class="invalid-feedback">Please choose a username.</div>
        </div>

        <div class="col-md-4">
          <label for="image.url" class="form-label">image url</label>
          <input
            type="text"
            name="listings[image][url]"
            id=""
            class="form-control"
            value="<%= hotel.image.url %>"
          />
          <div class="invalid-feedback">Please choose a username.</div>
        </div>
      </div>

      <div>
        <label for="price" class="form-label">price</label>
        <input
          type="number"
          name="listings[price]"
          value="<%= hotel.price %>"
          class="form-control"
          required
        />
        <div class="invalid-feedback">price is mandatory to enter</div>
      </div>

      <div>
        <label for="location" class="form-label">location</label>
        <input
          type="text"
          name="listings[location]"
          class="form-control"
          value="<%= hotel.location %>"
          required
        />

        <div class="invalid-feedback">Please choose a location.</div>
      </div>

      <div>
        <label for="country" class="form-label">country</label>
        <input
          type="text"
          name="listings[country]"
          value="<%= hotel.country %>"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Please choose a country.</div>
      </div>
      <br />
      <br />
      <div>
        <button class="btn btn-primary" type="submit">Submit form</button>
      </div>
    </form>
  </div>
</div>
